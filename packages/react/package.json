{
  "name": "@axiomui/react",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wwsheng009/axiomui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/wwsheng009/axiomui/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/wwsheng009/axiomui/tree/main/packages/react#readme",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@axiomui/tokens": "workspace:*"
  },
  "scripts": {
    "build": "vite build && node ./scripts/build-styles.mjs && node ./scripts/build-types.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vitest": "^4.1.2"
  }
}
